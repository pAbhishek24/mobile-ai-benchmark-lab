{
  "version": "1.0",
  "description": "Finance quality benchmark dataset for offline personal finance assistant evaluation. Each entry maps to a prompt_id in finance-benchmark-prompts.json and provides deterministic ground truth for automated scoring.",
  "scoring_rubric": {
    "numeric_tolerance_pct": 1.0,
    "partial_credit": true,
    "hallucination_penalty": 0.5
  },
  "categories": {
    "expense_summary":       { "weight": 1.0, "description": "Arithmetic correctness + percentage calculations" },
    "emi_pressure":          { "weight": 1.2, "description": "EMI ratio, sustainability assessment" },
    "credit_card_planning":  { "weight": 1.2, "description": "Interest calculation, payoff strategy" },
    "sip_planning":          { "weight": 1.1, "description": "Compound growth, goal-based calculation" },
    "lic_outflow":           { "weight": 1.0, "description": "Return analysis, opportunity cost" },
    "budget_overspend":      { "weight": 1.0, "description": "Overspend identification, actionable advice" },
    "safe_spend_remaining":  { "weight": 1.1, "description": "Cash position arithmetic, buffer awareness" },
    "debt_payoff":           { "weight": 1.2, "description": "Debt strategy, prioritization logic" },
    "category_spike":        { "weight": 1.0, "description": "Diagnostic framing, no hallucination" },
    "cashflow_warning":      { "weight": 1.3, "description": "Cash crunch identification, practical advice" }
  },
  "prompts": [
